# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/orderflow
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────
NEXTAUTH_SECRET=changeme-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ── LLM ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_DEFAULT_TIER=auto          # auto | haiku | sonnet | opus
LLM_CACHE_TTL=ephemeral        # ephemeral (5m) | 1h
LLM_BATCH_ENABLED=true

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_AI_METER=price_...
STRIPE_PRICE_TOPUP_10=price_...
STRIPE_PRICE_TOPUP_25=price_...
STRIPE_PRICE_TOPUP_50=price_...
STRIPE_PRICE_TOPUP_100=price_...

# ── Email ─────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM="OrderFlow <notify@orderflow.app>"

# ── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=...
TELEGRAM_BOT_USERNAME=OrderFlowBot

# ── Browser push (VAPID) ──────────────────────────────────
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
VAPID_SUBJECT=mailto:ops@orderflow.app

# ── Market Data ───────────────────────────────────────────
BINANCE_API_KEY=               # optional — public streams don't require auth
ALPACA_KEY_ID=
ALPACA_SECRET=
OANDA_ACCOUNT_ID=
OANDA_API_KEY=
TWELVE_DATA_API_KEY=
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=
FRED_API_KEY=

# ── Optional V1.1 paid feeds (user-supplied for "Desk" tier) ─
DATABENTO_API_KEY=
POLYGON_ADVANCED_KEY=

# ── Internal ──────────────────────────────────────────────
WS_GATEWAY_URL=ws://localhost:4001
API_URL=http://localhost:4000
WEBHOOK_HMAC_SECRET=changeme-generate-with-openssl-rand-hex-32
NODE_ENV=development
