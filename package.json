{
  "name": "orderflow",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "web:build": "bash scripts/web-build.sh",
    "web:deploy": "bash scripts/web-build.sh --restart",
    "verify:cache": "tsx scripts/verify-cache.ts"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@eslint/js": "^9.16.0",
    "@next/eslint-plugin-next": "^15.1.0",
    "eslint": "^9.16.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.14.0",
    "prettier": "^3.3.0",
    "tsx": "^4.22.1",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.18.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "pnpm": {
    "overrides": {
      "form-data": "^4.0.6"
    }
  }
}